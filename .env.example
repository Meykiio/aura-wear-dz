# Copy this file to .env and fill in the values for your own Supabase project.
# Never commit .env — keep this file (.env.example) as the documented reference.

# =============================================================================
# Supabase — Client (exposed to the browser via Vite's VITE_ prefix)
# =============================================================================
# Find these in: Supabase Dashboard → Project Settings → API
# - URL                  → Project URL
# - Publishable / anon   → "anon public" key
# - Project ID           → the subdomain in the URL (e.g. abcdef in abcdef.supabase.co)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi..."
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# =============================================================================
# Supabase — Server (used during SSR and inside server functions)
# =============================================================================
# Same URL and anon key as above, mirrored without the VITE_ prefix so the
# server bundle can read them via process.env.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi..."

# Service role key — SECRET. Bypasses RLS. Server-side only.
# Supabase Dashboard → Project Settings → API → "service_role" key.
# Never expose this in client code, never prefix with VITE_, never commit.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# =============================================================================
# Optional
# =============================================================================
# Override the hero video URL on the landing page. Falls back to a default CDN.
# VITE_HERO_VIDEO_URL="https://cdn.example.com/hero.mp4"
